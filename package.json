{
  "name": "react-native-nitro-notification",
  "version": "0.2.0",
  "description": "Remote push notifications (APNs) via Nitro Modules",
  "keywords": [
    "react-native",
    "ios",
    "android"
  ],
  "homepage": "https://github.com/Pnlvfx/react-native-nitro-notification#readme",
  "bugs": {
    "url": "https://github.com/Pnlvfx/react-native-nitro-notification/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Pnlvfx/react-native-nitro-notification.git"
  },
  "license": "MIT",
  "author": "Simone Gauli <simone@gauli.it> (https://github.com/Pnlvfx)",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "nitrogen",
    "nitro.json",
    "*.podspec",
    "react-native.config.js",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "workspaces": [
    "example"
  ],
  "scripts": {
    "build": "bob build",
    "clean": "del-cli android/build example/android/build example/android/app/build example/ios/build lib",
    "example": "yarn workspace react-native-nitro-notification-example",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "nitrogen": "nitrogen",
    "prepare": "bob build",
    "release": "node tools/release.ts",
    "update": "yarn upgrade-interactive"
  },
  "devDependencies": {
    "@goatjs/react-native-eslint": "^2.55.0",
    "@goatjs/typescript-config": "^2.2.0",
    "@react-native/babel-preset": "0.86.0",
    "@react-native/eslint-config": "0.86.0",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "babel-plugin-react-compiler": "1.0.0",
    "del-cli": "^7.0.0",
    "eslint": "^10.6.0",
    "execa": "^9.6.1",
    "nitrogen": "^0.35.10",
    "prettier": "^3.9.3",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-builder-bob": "^0.43.0",
    "react-native-nitro-modules": "^0.35.10",
    "turbo": "^2.10.1",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "react-native-nitro-modules": "*"
  },
  "packageManager": "yarn@4.17.0+sha512.c2957de2f9025ab14d63b24d0d8be1f1655810e22c341042c27f7ecd017b180ec12db73d69ac366d71b304ef9f069349ce462de96f04f8f1da317f4f762c95ae",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "create-react-native-library": {
    "type": "nitro-module",
    "languages": "kotlin-swift",
    "tools": [
      "eslint"
    ],
    "version": "0.57.2"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "custom",
        {
          "script": "nitrogen",
          "clean": "nitrogen/"
        }
      ],
      [
        "module",
        {
          "esm": true,
          "configFile": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  }
}
