{
  "extends": ["@goatjs/typescript-config/base/tsconfig.json"],
  "include": ["babel.config.js", "src", "example", "eslint.config.js", "tools"],
  "compilerOptions": {
    "rootDir": ".",
    "paths": {
      "react-native-nitro-notification": ["./src/index"]
    },
    "customConditions": ["react-native-strict-api"],
    "jsx": "react-jsx",
    "lib": ["ESNext"],
    "types": ["node"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "resolveJsonModule": true,
    "target": "ESNext"
  }
}
