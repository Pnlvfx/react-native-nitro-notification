{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": ["nitronotification"],
  "ios": {
    "iosModuleName": "NitroNotification"
  },
  "android": {
    "androidNamespace": ["nitronotification"],
    "androidCxxLibName": "nitronotification"
  },
  "autolinking": {
    "NitroNotification": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridNitroNotification"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridNitroNotification"
      }
    }
  },
  "ignorePaths": ["node_modules"]
}
